  mH_12_GG_OPTS = --add-logo --add-ratios 1 --legend-ncol 3 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO) $(ggNLO) $(ggNNLO)
  costh_j12_GG_OPTS = --histogram --y-logscale --add-logo --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO) $(ggNLO) $(ggNNLO)
  dR_j12_GG_OPTS = --histogram --y-logscale --add-logo --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO) $(ggNLO) $(ggNNLO)
  ej1_GG_OPTS = --histogram --add-logo --y-logscale --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO_over_mH) $(ggNLO_over_mH) $(ggNNLO_over_mH) --rescale 125.09
  ej2_GG_OPTS = --histogram --add-logo --y-logscale --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO_over_mH) $(ggNLO_over_mH) $(ggNNLO_over_mH) --rescale 125.09
  yj1_GG_OPTS = --histogram --add-logo --y-logscale --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO) $(ggNLO) $(ggNNLO)
  yj2_GG_OPTS = --histogram --y-logscale --add-logo --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO) $(ggNLO) $(ggNNLO)
