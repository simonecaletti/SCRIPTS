  # Observable-specific options for GG
  mZ_GG_OPTS = --histogram --add-logo --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO) $(ggNLO) $(ggNLO)
  costh_l12_GG_OPTS = --histogram --add-logo --y-logscale --legend-ncol 3 --add-ratios 1 --set-ratios '[[2, 1, 3]]' --normalize $(ggLO) $(ggNLO) $(ggNNLO)
