	@cd ../15 && \
	rm -rf hbb15nnlo/combined hbb15nnlo/combined.temp hgg15nnlo/combined hgg15nnlo/combined.temp

clean_rebin: clean_rebin14 clean_rebin15

 clean:
	rm -f $(GG_OUTDIR)/*.pdf
	rm -f $(GGmid_OUTDIR)/*.pdf
	rm -f $(GGsmall_OUTDIR)/*.pdf
	rm -f $(BB_OUTDIR)/*.pdf
	rm -f $(BBmid_OUTDIR)/*.pdf
	rm -f $(BBsmall_OUTDIR)/*.pdf
	rm -f $(TOT_OUTDIR)/*.pdf
	rm -f $(TOTmid_OUTDIR)/*.pdf
	rm gallery.html
