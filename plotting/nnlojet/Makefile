  # Observable-specific options for TOT
  mZ_TOT_OPTS = --histogram --place-text 3 --add-logo --legend-ncol 2 --add-ratios 1 --set-ratios '[[1,2, 3, 4]]' --normalize $(tot2NNLO) $(tot2NNLO) $(tot2NNLO) $(tot2NNLO)
  costh_l12_TOT_OPTS = --histogram --add-logo --legend-ncol 2 --y-logscale --place-text 3 --add-ratios 1 --set-ratios '[[1,2, 3, 4]]' --normalize $(tot2NNLO) $(tot2NNLO) $(tot2NNLO) $(tot2NNLO)
