# Makefile with flexible input files

PYTHON = python3
DATADIR = ../

# Output directories
GG_OUTDIR = figures/hgg
GGmid_OUTDIR = figures/hggmid
GGsmall_OUTDIR=figures/hggsmall
BB_OUTDIR = figures/hbb
BBmid_OUTDIR = figures/hbbmid
BBsmall_OUTDIR=figures/hbbsmall
TOT_OUTDIR = figures/tot
TOTmid_OUTDIR = figures/totmid
TOTsmall_OUTDIR = figures/totsmall
# Config files
CONFIG_GG= config/GG/
CONFIG_BB= config/BB/
CONFIG_TOT=config/TOT/
CONFIG_GGmid=config/GGmid/
CONFIG_BBmid=config/BBmid/
CONFIG_TOTmid=config/TOTmid/
CONFIG_GGsmall=config/GGsmall/
CONFIG_BBsmall=config/BBsmall/
CONFIG_TOTsmall=config/TOTsmall/

INCL = \
  mH_all mH_12 mH_rec costh_j12 ej1\
  ej2 min_costh_lpj min_costh_lmj
RATES = y12 y12_log y23_log y34_log
EXCL := $(foreach incl,$(INCL),$(incl)_excl2)
NAMES := $(INCL) $(EXCL) $(RATES)
INCL_EXCL := $(INCL) $(EXCL)

# Total cross section full inclusive
bbLO=3.6828205
bbNLO=4.43100509
bbNNLO=4.56900509

# Obtained from bb by Yukawa rescaling
ccLO=0.3474252604336735
ccNLO=0.41800655160255107
ccNNLO=0.43102502099030615

ggLO=0.35380214
ggNLO=0.5112966
ggNNLO=0.54251662

# Sum of bb + gg
tot1LO=4.03662264
tot1NLO=4.94230169
tot1NNLO=5.11152171

#Sum of bb + cc + gg
tot2LO=4.384047900433673
tot2NLO=5.360308241602551
tot2NNLO=5.542546730990306

# Normalization for Ej1 and Ej2
# (we want d\sigma/d(E/mH) distributions)
bbLO_over_mH=0.029441366216324247
bbNLO_over_mH=0.03542253649372452
bbNNLO_over_mH=0.03652574218562635
ccLO_over_mH=0.00277740235377467
ccNLO_over_mH=0.0033416464273926857
ccNNLO_over_mH=0.0034457192500624042
ggLO_over_mH=0.0028283806859061475
ggNLO_over_mH=0.004087429850507634
ggNNLO_over_mH=0.004337010312574946
tot2LO_over_mH=0.035047149256005064
tot2NLO_over_mH=0.04285161277162484
tot2NNLO_over_mH=0.044308471748263696

